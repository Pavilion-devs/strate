{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "src/**/*.ts",
    "cli/index.ts",
    "cli/bootstrap.ts",
    "cli/solana-bootstrap.ts",
    "cli/**/*.tsx"
  ]
}
